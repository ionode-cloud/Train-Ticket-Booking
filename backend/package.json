{
  "name": "train-booking-backend",
  "version": "1.0.0",
  "description": "Train Ticket Booking App Backend",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "dev:fresh": "node -e \"const {execSync}=require('child_process');try{execSync('netstat -ano | findstr :5000').toString().split('\\n').filter(l=>l.includes('LISTENING')).forEach(l=>{const pid=l.trim().split(/\\s+/).pop();if(pid&&pid!=='0')execSync('taskkill /PID '+pid+' /F',{stdio:\\'ignore\\'})})}catch(e){}\" && nodemon server.js",
    "seed": "node seed.js"
  },
  "dependencies": {
    "axios": "^1.14.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "mongoose": "^8.2.1",
    "nodemailer": "^6.9.12",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}
